{
  "expo": {
    "name": "Yomu",
    "slug": "Yomu",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/yomu.png",
    "scheme": "yomu",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "6"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/yomu.png",
        "backgroundImage": "./assets/images/yomu.png",
        "monochromeImage": "./assets/images/yomu.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "id.my.basth.yomu",
      "versionCode": 6
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/appLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/yomu-crop.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0e0d0f",
          "dark": {
            "backgroundColor": "#0e0d0f"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Audiowide-Regular.ttf",
            "./assets/fonts/Lora-Regular.ttf",
            "./assets/fonts/Lora-Italic.ttf",
            "./assets/fonts/Lora-Bold.ttf",
            "./assets/fonts/Lora-BoldItalic.ttf",
            "./assets/fonts/Literata-VariableFont_opsz,wght.ttf",
            "./assets/fonts/Literata-Italic-VariableFont_opsz,wght.ttf",
            "./assets/fonts/Merriweather-VariableFont_opsz,wdth,wght.ttf",
            "./assets/fonts/Merriweather-Italic-VariableFont_opsz,wdth,wght.ttf"
          ]
        }
      ],
      "expo-sqlite",
      "@clerk/expo",
      "expo-secure-store",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7279615482242846~2254635969",
          "iosAppId": "ca-app-pub-7279615482242846~2254635969"
        }
      ],
      "./plugins/withAndroidKeystore"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
